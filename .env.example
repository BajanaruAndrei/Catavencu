# Tokenul botului tău de Telegram obținut de la @BotFather
TELEGRAM_BOT_TOKEN=

# ID-ul chat-ului de Telegram (utilizator, grup sau canal) unde se trimite digestul
TELEGRAM_CHAT_ID=
